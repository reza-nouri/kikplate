
# PostgreSQL connection used by the API service.
database:
  host: localhost
  port: 5432
  database: kikplate
  username: postgres
  password: password

# HTTP server settings for the Go API.
server:
  # Port the API listens on.
  port: 3001
  # Public URL of the frontend app. Used in redirects and auth flows.
  frontend_url: http://localhost:3000
  log:
    # Supported values depend on the logger setup. `info` is the safe default.
    level: info

# Repository sync worker settings.
sync:
  # How often a full sync cycle should run.
  interval: 6h
  # Delay between polling attempts while processing sync work.
  poll_interval: 30s
  # Number of items handled in each sync batch.
  batch_size: 25

# Local email/password authentication settings.
auth:
  email_verification:
    # When false, users registered via /auth/register are active immediately.
    # When true, users must verify their email before login is allowed.
    enabled: false
    # Expiration duration for verification links.
    token_ttl: 24h
    # Optional absolute URL used for links in verification emails.
    # If omitted, server.frontend_url + /verify-email is used.
    verify_url_base: http://localhost:3000/verify-email

# SMTP settings used only when auth.email_verification.enabled=true.
# Example below matches Amazon SES SMTP endpoint style.
smtp:
  host: email-smtp.us-east-1.amazonaws.com
  port: 587
  username: your_ses_smtp_username
  password: your_ses_smtp_password
  from_email: no-reply@example.com
  from_name: Kikplate
  use_starttls: true

# OAuth / SSO providers exposed by the API.
sso:
  providers:
    - name: github
      client_id: your_github_client_id
      client_secret: your_github_client_secret
      redirect_url: http://localhost:3000/api/auth/github/callback
      scopes:
        - read:user
        - user:email
    - name: google
      client_id: your_google_client_id
      client_secret: your_google_client_secret
      redirect_url: http://localhost:3000/api/auth/google/callback
      scopes:
        - openid
        - email
        - profile

# Frontend-only branding and hero configuration exposed through GET /config.
customization:
  # Logo URL used in the navbar.
  # Local example: a file from web/public.
  # Kubernetes example: a CDN/object-storage URL managed via ConfigMap.
  logo: "https://kikplate.dev/kikplate-logo-on-dark.svg"

  # Main hero title on the landing page.
  # Use \n to force a line break.
  banner_title: "The biggest library of\nstarter boilerplates"

  # Social links shown in the hero section.
  social_media:
    - type: github
      link: "https://github.com/kikplate/kikplate"
    - type: slack
      link: ""
    - type: linkedin
      link: "https://www.linkedin.com/company/kikplate"
    - type: x
      link: "https://x.com/kikplate"

  # Clickable suggested searches shown below the hero search box.
  prepared_queries:
    - "Golang starter"
    - "Clean architecture boilerplate for Nodejs"
    - "Go Chi REST"
    - "Python http server"
    - "Next.js"
    - "Gin framework"
    - "Postgresql docker-compose"
    - "Nginx"

# Allowed values for kikplate.yaml `category`, browse-by-category UI, and filters.
# Omit this key to use the built-in default list. Unknown or empty categories map to `other`.
plate_categories:
  - slug: backend
    label: Backend
    description: APIs, services, microservices
    icon: server
  - slug: frontend
    label: Frontend
    description: Web UIs, SPAs, SSR apps
    icon: globe
  - slug: fullstack
    label: Full Stack
    description: End-to-end project starters
    icon: layers
  - slug: mobile
    label: Mobile
    description: iOS, Android, cross-platform
    icon: smartphone
  - slug: cli
    label: CLI
    description: Command line tools & scripts
    icon: terminal
  - slug: devops
    label: DevOps
    description: Docker, CI/CD, infrastructure
    icon: wrench
  - slug: library
    label: Library
    description: Reusable packages and SDKs
    icon: package
  - slug: database
    label: Database
    description: Schemas, migrations, seeds
    icon: database
  - slug: cloud
    label: Cloud
    description: AWS, GCP, Azure starters
    icon: cloud
  - slug: security
    label: Security
    description: Auth, encryption, compliance
    icon: shield
  - slug: iot
    label: IoT
    description: Embedded, edge, hardware
    icon: cpu
  - slug: game
    label: Game Dev
    description: Game engines, frameworks
    icon: gamepad-2
  - slug: documentation
    label: Documentation
    description: Docs sites, wikis, guides
    icon: book-open
  - slug: ai-ml
    label: AI / ML
    description: Machine learning, LLMs, data
    icon: bot
  - slug: other
    label: Other
    description: Everything else
    icon: more-horizontal