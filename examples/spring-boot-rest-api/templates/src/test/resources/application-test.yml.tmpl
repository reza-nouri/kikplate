spring:
  application:
    name: {{ .appName }}-test
  datasource:
    url: jdbc:h2:mem:{{ .artifactId }}_test;MODE=PostgreSQL;DATABASE_TO_LOWER=TRUE;DEFAULT_NULL_ORDERING=HIGH
    username: sa
    password:
    driver-class-name: org.h2.Driver
  jpa:
    hibernate:
      ddl-auto: create-drop
    show-sql: false

server:
  port: 0
